[TEMPLATE]
# InfoTriage — environment variables
# Copy to .env and fill in real values. .env is gitignored — never commit secrets.

# ── LLM — primary: DGX Spark (vLLM, qwen 80B); fallback: oMLX on Mac ────────
# Primary: DGX Spark via vLLM (use when Spark is reachable)
# LLM_BASE_URL=http://192.168.10.2:8000/v1
# LLM_API_KEY=EMPTY
# LLM_MODEL=<model-name-as-served-by-vllm>
#
# Fallback: oMLX on Mac (works standalone without Spark)
LLM_BASE_URL=http://127.0.0.1:8000/v1
LLM_API_KEY=omlx
LLM_MODEL=qwen36-ud-4bit

# ── Embedder ──────────────────────────────────────────────────────────────────
# Mac (oMLX): intfloat/multilingual-e5-large (1024-dim, multilingual, default)
EMBED_BASE_URL=http://127.0.0.1:8000/v1
EMBED_MODEL=intfloat/multilingual-e5-large
# Spark (vLLM, when available): gte-Qwen2-7B-instruct (transfer model from Mac — Spark has no internet)
# EMBED_BASE_URL=http://192.168.10.2:8000/v1
# EMBED_MODEL=Alibaba-NLP/gte-Qwen2-7B-instruct

# ── FreshRSS Fever API (REMOVED 2026-07-11, Phase 7 retire) ─────────────────
# The Fever-poll path was cut over to event-driven triage in Phase 5
# (commit 1849f2a, HANDOFF decision R6). apps/triage/fever_triage.py and the
# host crontab entry are gone; nothing in services/ code reads FRESHRSS_FEVER_*
# anymore. FreshRSS still exposes its own /fever.php endpoint if you ever
# need it from an external client — set the vars yourself in `.env`.

# ── Postgres (Phase 2+) ───────────────────────────────────────────────────────
# Dev default set in docker-compose.yml; override here for non-default passwords.
POSTGRES_PASSWORD=infotriage_dev
# Full DSN used by adapters inside the Docker network (postgres = service name)
INFOTRIAGE_PG_DSN=postgresql://infotriage:infotriage_dev@postgres:5432/infotriage

# ── RabbitMQ (Phase 3+) ───────────────────────────────────────────────────────
RABBITMQ_DEFAULT_USER=infotriage
RABBITMQ_DEFAULT_PASS=infotriage_rmq
# AMQP DSN used by adapters inside the Docker network (rabbitmq = service name)
INFOTRIAGE_AMQP_DSN=amqp://infotriage:infotriage_rmq@rabbitmq:5672

# ── Phase 4: Ingest adapters + Gmail MCP ─────────────────────────────────────

# Blob storage root (inside container — mounted from ./data on host)
INFOTRIAGE_BLOB_ROOT=/data/blobs

# Obsidian vault host path — bind-mounted read-only into ingest-obsidian as /vault
# Set to the absolute path of your Obsidian vault on the host.
OBSIDIAN_VAULT_PATH=
CLUSTER_THRESHOLD=0.75
VAULT_INCLUDE_EMAIL=1

# Gmail MCP server — internal Docker URL (set automatically via docker-compose env)
GMAIL_MCP_URL=http://gmail-mcp-server:3000

# Gmail OAuth2 credentials (write once by running: python scripts/provision_gmail_oauth.py)
# provision_gmail_oauth.py completes the browser OAuth2 flow and writes GMAIL_OAUTH2_REFRESH_TOKEN here.
GMAIL_OAUTH2_CLIENT_ID=
GMAIL_OAUTH2_CLIENT_SECRET=
GMAIL_OAUTH2_REFRESH_TOKEN=

# Gmail query filter for ingest-gmail adapter (default: messages from the past 7 days)
GMAIL_QUERY=newer_than:7d

# ── Phase 4: Per-adapter cron schedules (APScheduler crontab syntax) ──────────
# Defaults match scheduler_main.py; override here to change ingest frequency.
# SCHEDULE_IMAP=0 */2 * * *       # every 2 hours (default)
# SCHEDULE_YOUTUBE=0 */4 * * *    # every 4 hours (default)
# SCHEDULE_GMAIL=0 */2 * * *      # every 2 hours (default)
# SCHEDULE_OBSIDIAN=*/30 * * * *  # every 30 minutes (default)
SCHEDULE_IMAP=0 */2 * * *
SCHEDULE_YOUTUBE=0 */4 * * *
SCHEDULE_GMAIL=0 */2 * * *
SCHEDULE_OBSIDIAN=*/30 * * * *
# Phase 11 adapters (uncomment when adapters are enabled):
# SCHEDULE_TELEGRAM=0 */6 * * *
# SCHEDULE_BARENTSWATCH=0 */12 * * *

# ── Translation on demand (Phase 11 Wave 4) ─────────────────────────────────
# Set to 1 to enable local-LLM translation of non-en/no items in brief/vault.
TRANSLATION_ENABLED=0
TRANSLATION_TARGET_LANG=no
# Comma-separated list of language codes to skip translation for (default: en,no,und).
# Telegram posts default to lang="und"; add or remove entries to control cost.
# Empty string means "skip nothing" (i.e. translate everything except en/no/und).
TRANSLATION_SKIP_LANGS=en,no,und

# ── YouTube transcription (Phase 11 Wave 5) ─────────────────────────────────
# Set to 1 to enable local faster-whisper transcription of YouTube audio.
INFOTRIAGE_YOUTUBE_TRANSCRIBE=0
INFOTRIAGE_WHISPER_MODEL=tiny

# ── Multi-protocol mail (apps/ingest-imap) — IMAP + POP3 ──────────────────
# Per spec: protocol ∈ {"imap", "pop3"} (default: imap). Gmail defaults to
# IMAP via provider: gmail (X-GM-RAW). POP3 fetches return up to 60 most-recent
# messages, keyed by the server-allocated UIDL for stable per-message dedup.
# All protocols are read-only — no DELE/EXPUNGE/APPEND/COPY/STORE.
# export MAILBOXES='[
#   {"name":"gmail","provider":"gmail","host":"imap.gmail.com","user":"you@gmail.com","password":"app-pw"},
#   {"name":"newsletter-pop3","protocol":"pop3","host":"pop.example.com","user":"me","password":"..."}
# ]'

# ── YouTube channels (apps/ingest-youtube) ───────────────────────────────────
# export YT_CHANNELS='[{"channel":"@BBCNews","name":"BBC News","transcribe":false}]'

# ── Phase 11: SOCMINT / Arctic adapters ──────────────────────────────────────
# Telegram (SOCMINT) — get api_id/api_hash from https://my.telegram.org
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Comma-separated list of public channel identifiers to monitor, e.g.:
# TELEGRAM_CHANNELS=channelname1,channelname2

# BarentsWatch AIS (MASINT/AIS) — register at https://www.barentswatch.no
BARENTSWATCH_CLIENT_ID=
BARENTSWATCH_CLIENT_SECRET=
# Optional bounding box or area filter, e.g. "70,20,72,30"
# BARENTSWATCH_AREA=

# ── Phase 12 sub-wave (a): ntfy push channel (sealed-bind-mount per ADR-017 addendum) ─
# ntfy-sh/ntfy container is bound to 127.0.0.1:22070 (local-only per ADR-016).
# Override the base URL if running behind a reverse proxy or on a different host.
NTFY_BASE_URL=http://127.0.0.1:22070
# Topic prefix — alerting layer publishes to "${NTFY_TOPIC_PREFIX}" (default: cnr-cat-i).
NTFY_TOPIC_PREFIX=cnr-cat-i

# ACL bootstrap pattern: SEALED BIND-MOUNT (per ADR-017 addendum, 2026-07-23).
# On first install, run `make ntfy-seed` (calls scripts/seed_ntfy_sealed.py) to
# produce configs/ntfy-sealed/auth.db + configs/ntfy-sealed/server.yml. The
# container bind-mounts these read-only; ntfy serves with no in-container
# bootstrap. No NTFY_AUTH_DEFAULT_ACCESS env needed — that lives in server.yml.
#
# The producer / reader plaintext credentials below are used by the sub-wave (c)
# emit-side client. ntfy receives them over HTTP basic auth and validates
# against the bcrypt-hashed values sealed in auth.db. They MUST match what
# `make ntfy-seed` wrote into auth.db; the script reads from the same env vars.
NTFY_PRODUCER_USER=producer
NTFY_PRODUCER_PASSWORD=changeme
NTFY_READER_USER=reader
NTFY_READER_PASSWORD=changeme

# Operator workflow:
#   make ntfy-seed              # one-time, idempotent; re-run with --force to wipe
#   make ntfy-up                # bring up the sealed ntfy container
#   make ntfy-publish-test      # smoke test (POST → 401 because deny-all)
#
# Per ADR-017 Decision 3: both passwords default to `changeme` for dev. The
# seed script logs a WARNING when this is detected (does NOT fail-fast).
# Production rollout requires overriding both .env values + adding a
# commit-time secret scanner (a future ADR).

# ACLED — paid license required for ingestion (ADR-014)
ACLED_LICENSE_KEY=
