# trimail — environment variables
# Copy to .env and fill in real values. .env is gitignored — never commit secrets.

# ── Local LLM (your Mac) ────────────────────────────────────────────
# oMLX default. Swap to Ollama: http://127.0.0.1:11434/v1 , key "ollama".
LLM_BASE_URL=http://127.0.0.1:8000/v1
LLM_API_KEY=omlx
LLM_MODEL=qwen36-ud-4bit

# ── FreshRSS Fever API ───────────────────────────────────────────────
# Enable in FreshRSS: Settings ▸ Authentication ▸ API.
# Then set API password: Settings ▸ Profile ▸ API password.
FRESHRSS_FEVER_URL=http://localhost:8088/api/fever.php
FRESHRSS_FEVER_USER=admin
FRESHRSS_FEVER_API_PASSWORD=

# ── Gmail bridge (bridge/gmail_to_atom.py) ───────────────────────────
# Use a Google App Password (Account ▸ Security ▸ 2-Step ▸ App passwords),
# NOT your real password. trimail is read-only (readonly=True IMAP).
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Gmail search syntax — which newsletters to pull.
GMAIL_QUERY=newer_than:7d

# ── Multi-mailbox IMAP (bridge/imap_to_atom.py) ─────────────────────
# Not loadable from .env (JSON array — the loader skips non-KEY=VALUE lines).
# Either export via shell or write a sibling .mailboxes.json file.
# export MAILBOXES='[{"provider":"gmail","user":"you@gmail.com","password":"app-pw","host":"imap.gmail.com"}]'
# See bridge/imap_to_atom.py for full schema.

# ── YouTube channels (bridge/yt_to_atom.py) ─────────────────────────
# Same pattern: export or write .yt_channels.json.
# export YT_CHANNELS='[{"channel":"@BBCNews","name":"BBC News","transcribe":false}]'
# See bridge/yt_to_atom.py for full schema.
