[TEMPLATE]
# InfoTriage — environment variables
# Copy to .env and fill in real values. .env is gitignored — never commit secrets.

# ── LLM — primary: DGX Spark (vLLM, qwen 80B); fallback: oMLX on Mac ────────
# Primary: DGX Spark via vLLM (use when Spark is reachable)
# LLM_BASE_URL=http://192.168.10.2:8000/v1
# LLM_API_KEY=EMPTY
# LLM_MODEL=<model-name-as-served-by-vllm>
#
# Fallback: oMLX on Mac (works standalone without Spark)
LLM_BASE_URL=http://127.0.0.1:8000/v1
LLM_API_KEY=omlx
LLM_MODEL=qwen36-ud-4bit

# ── Embedder ──────────────────────────────────────────────────────────────────
# Mac (oMLX): intfloat/multilingual-e5-large (1024-dim, multilingual, default)
EMBED_BASE_URL=http://127.0.0.1:8000/v1
EMBED_MODEL=intfloat/multilingual-e5-large
# Spark (vLLM, when available): gte-Qwen2-7B-instruct (transfer model from Mac — Spark has no internet)
# EMBED_BASE_URL=http://192.168.10.2:8000/v1
# EMBED_MODEL=Alibaba-NLP/gte-Qwen2-7B-instruct

# ── FreshRSS Fever API ───────────────────────────────────────────────
FRESHRSS_FEVER_URL=http://localhost:8088/api/fever.php
FRESHRSS_FEVER_USER=admin
FRESHRSS_FEVER_API_PASSWORD=

# ── Gmail bridge (bridge/gmail_to_atom.py) ───────────────────────────
GMAIL_USER=
GMAIL_APP_PASSWORD=
GMAIL_QUERY=newer_than:7d

# ── Multi-mailbox IMAP (bridge/imap_to_atom.py) ─────────────────────
# export MAILBOXES='[{"provider":"gmail","user":"you@gmail.com","password":"app-pw","host":"imap.gmail.com"}]'

# ── YouTube channels (bridge/yt_to_atom.py) ─────────────────────────
# export YT_CHANNELS='[{"channel":"@BBCNews","name":"BBC News","transcribe":false}]'
